<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    tools:context=".Score">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Félicitations !"
            android:textColor="#4F46E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Votre score est prêt"
            android:textColor="#374151"
            android:textSize="24sp"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="40dp"
                android:background="@android:color/white">

                <TextView
                    android:id="@+id/tvFinalScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25 / 30"
                    android:textColor="#4F46E5"
                    android:textSize="72sp"
                    android:fontFamily="sans-serif-black" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="4dp"
                    android:background="#E5E7EB"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvIqComment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Excellent travail !"
                    android:textColor="#10B981"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:background="#CCFFFFFF"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tvLocationDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chargement de la carte..."
                        android:textColor="#374151"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToMenu"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="RETOUR AU MENU"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            android:backgroundTint="#4F46E5"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconGravity="textStart"
            android:elevation="4dp" />

    </LinearLayout>
</RelativeLayout>